# ---- Server ----
PORT=3000
# Comma-separated list of front-end origins allowed to call this API (CORS).
# In dev this is your Vite/SvelteKit/static server. In prod, your real domain.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Database ----
# Local dev example. On Fly/Railway this is injected for you.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/respawn

# ---- IGDB / Twitch ----
# Create these at https://dev.twitch.tv/console/apps (Client Type: Confidential).
# IGDB authenticates via Twitch OAuth using these.
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
